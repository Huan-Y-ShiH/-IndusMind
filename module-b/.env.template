# 复制为 .env 后填入真实值；不要在任何可提交文件中写密钥。
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-reasoner

# 使用 127.0.0.1 而非 localhost，避免 macOS 系统代理劫持成本地 503
DIFY_BASE_URL=http://127.0.0.1/v1
DIFY_DATASET_API_KEY=
DIFY_CASES_DATASET_ID=
DIFY_MANUALS_DATASET_ID=

OTEL_SDK_DISABLED=true
CREWAI_TRACING_ENABLED=false
DIAGNOSTIC_FLOW_TIMEOUT_SECONDS=90
L2L3_CREW_TIMEOUT_SECONDS=60
# true=始终输出最可能根因+LLM逻辑链，跳过低置信度人工门禁（联调/演示）
DIAGNOSTIC_ALWAYS_TOP1=false

# Server酱 Turbo（https://sct.ftqq.com/）微信推送中转；真实 SendKey 只放 .env
NOTIFY_ENABLED=false
SERVERCHAN_SENDKEY=

# 本地 Agent HTTP（默认 :8002；当前云端经 ECS/frp 固定入口访问）
API_KEY=
AGENT_HOST=0.0.0.0
AGENT_PORT=8002
CORS_ORIGINS=*

# SlideForge PPT 渲染（可选；真实 Key 只放被忽略的 .env）
SLIDEFORGE_API_KEY=
